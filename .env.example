# =========================================================================
# vn-news-summarizer — environment variables
# Copy to .env and fill in. NEVER commit .env.
# =========================================================================

# --- Database -------------------------------------------------------------
# MVP default: SQLite at ./data/app.db
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# When ready to switch to Postgres (docker-compose service `db`):
# DATABASE_URL=postgresql+asyncpg://vn_news:vn_news@localhost:5432/vn_news

# --- Redis (optional, for cache + Celery later) ---------------------------
REDIS_URL=redis://localhost:6379/0

# --- Vertex AI (Google Cloud) for LLM labeling ----------------------------
# Project ID and region of your GCP project with Vertex AI enabled.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-southeast1
# Path to service account JSON with role "Vertex AI User".
# Place the file outside the repo or under ./secrets/ (gitignored).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/vertex-sa.json
# Default model used for labeling.
VERTEX_LLM_MODEL=gemini-2.5-flash

# --- Crawler --------------------------------------------------------------
CRAWLER_USER_AGENT=vn-news-summarizer-research/0.1 (+https://github.com/khangnh22ds/vn-news-summarizer)
CRAWLER_REQUESTS_PER_SECOND=1.0
CRAWLER_TIMEOUT_SECONDS=20
CRAWLER_MAX_RETRIES=3

# --- API ------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
# Token for /api/admin/* endpoints (basic auth bearer).
ADMIN_TOKEN=change-me-to-a-long-random-string

# --- Frontend (Next.js) ---------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Inference / Model ----------------------------------------------------
# Path to the fine-tuned model directory (Phase 4 output).
MODEL_PATH=./models/vit5-news-v1
# Fall back to Vertex AI LLM if local model summary fails QC.
ENABLE_LLM_FALLBACK=true

# --- MLflow ---------------------------------------------------------------
MLFLOW_TRACKING_URI=file:./mlruns

# --- Misc -----------------------------------------------------------------
LOG_LEVEL=INFO
TZ=Asia/Ho_Chi_Minh
